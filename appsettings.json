{
  // ===== 部署形态 =====
  // 部署模式标识。可选值：
  //   "docker" -> 标准 Docker 容器部署（默认）。会触发 Program.InitApplicationServices 中的
  //               cookieService.InitCookie() 自动建一份默认 Cookie 占位。
  //   "fn"     -> 飞牛 NAS（fnOS）fpk 包部署。FFmpegHelper / ServiceExtension 会按 fn 路径
  //               规则解析数据目录；ConfigController 的版本接口会返回 fn_${fnVersion}。
  //   ""或其他 -> 普通本机/源码部署，不做任何特殊初始化。
  // 调用点：Program.cs / ConfigController.cs / ServiceExtension.cs / FFmpegHelper.cs
  "deploy": "docker",

  // ===== 数据库 =====
  // 自定义数据库连接字符串。当前全部走 SQLite 且路径由代码自动生成
  // （见 ServiceExtension.CreateSqliteDBConn），此字段保留为兼容字段，留空即可。
  "dbconn": "",

  // 数据库类型，大小写不敏感，会被解析为 SqlSugar 的 DbType 枚举。
  // 当前实际只支持 "Sqlite"，其他值会回退到默认 Sqlite。
  "dbtype": "Sqlite",

  // ===== 版本与更新检查 =====
  // 当前发布镜像/包的 tag 名称，前端调"检查更新"接口时显示，并作为参数请求
  // dockerTagsBaseUrl + tagName 拉取最新可用版本列表。
  // Docker 镜像通常是 "beta_x.y.z"；arm 镜像是 "arm_x.y.z"；fn 部署会被改写成 "fn_${fnVersion}"。
  "tagName": "beta_2.1.8",

  // 飞牛 NAS（fnOS）fpk 包的版本号，仅在 deploy == "fn" 时生效，组合成 fn_${fnVersion}
  // 用于版本比对。Docker 部署可保留默认值。
  "fnVersion": "1.0.0",

  // Docker tag 查询服务的基础 URL（必须以 '/' 结尾）。
  // 由 dy.sync.lib.DouyinHttpHelper.GetTenImage 读取，
  // 实际请求地址为 dockerTagsBaseUrl + tagName。
  // 缺失或为空时该接口会抛 InvalidOperationException 并被全局异常过滤器拦截。
  "dockerTagsBaseUrl": "http://nas.synology2023.online:10108/api/docker/dysync/"
}
